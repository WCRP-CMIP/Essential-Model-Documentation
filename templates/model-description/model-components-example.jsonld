{
  "@context": {
    "@vocab": "https://wcrp-cmip.org/emd/",
    "emd": "https://wcrp-cmip.org/emd/",
    "dcterms": "http://purl.org/dc/terms/",
    "prov": "http://www.w3.org/ns/prov#",
    "gcmd": "https://gcmd.earthdata.nasa.gov/kms/concepts/concept_scheme/sciencekeywords/"
  },
  "@type": "emd:ModelComponents",
  "@id": "https://mpimet.mpg.de/models/mpi-esm-1-2-lr/components",
  
  "emd:parentModelId": "https://mpimet.mpg.de/models/mpi-esm-1-2-lr",
  "emd:parentModelName": "MPI-ESM1.2-LR",
  
  "emd:components": {
    "atmosphere": {
      "@type": "emd:ModelComponent",
      "@id": "https://mpimet.mpg.de/models/mpi-esm-1-2-lr/components/atmosphere",
      "emd:componentName": "ECHAM6.3",
      "emd:componentType": "atmosphere",
      "emd:componentVersion": "6.3",
      "dcterms:description": "Atmospheric general circulation model based on the ECMWF model, adapted and developed at MPI-M",
      
      "emd:spatialDiscretization": {
        "@type": "emd:Grid",
        "emd:gridType": "spectral",
        "emd:horizontalResolution": "T63 (~1.875°)",
        "emd:horizontalGridPoints": 18432,
        "emd:verticalResolution": "hybrid sigma-pressure",
        "emd:verticalLevels": 47,
        "emd:topHeight": "0.01 hPa",
        "emd:verticalCoordinateScheme": "Hybrid sigma-pressure coordinate with terrain-following lower levels and pressure levels aloft"
      },
      
      "emd:temporalDiscretization": {
        "@type": "emd:TimeStep",
        "emd:dynamicalCoreTimeStep": 450,
        "emd:physicsTimeStep": 450,
        "emd:radiationTimeStep": 7200,
        "emd:timeStepUnit": "seconds",
        "emd:timeIntegrationScheme": "semi-implicit"
      },
      
      "emd:dynamicalCore": {
        "@type": "emd:DynamicalCore",
        "emd:coreName": "ECHAM Spectral Transform",
        "emd:coreType": "spectral",
        "emd:prognosticVariables": ["vorticity", "divergence", "temperature", "surface_pressure", "specific_humidity", "cloud_water", "cloud_ice"],
        "emd:conservedQuantities": ["mass", "energy", "angular_momentum"]
      },
      
      "emd:physicalParameterizations": {
        "radiation": {
          "scheme": "RRTMG",
          "shortwave": "RRTMG-SW with 14 bands",
          "longwave": "RRTMG-LW with 16 bands",
          "spectralBands": 30
        },
        "convection": {
          "scheme": "Tiedtke-Nordeng",
          "deepConvection": "Mass flux scheme with CAPE closure",
          "shallowConvection": "Bulk mass flux scheme",
          "trigger": "Large-scale moisture convergence"
        },
        "clouds": {
          "scheme": "Sundqvist prognostic cloud scheme",
          "prognosticVariables": ["cloud_fraction", "cloud_liquid_water", "cloud_ice_water"],
          "microphysics": "Two-moment scheme"
        },
        "turbulence": {
          "scheme": "TKE-based scheme",
          "surfaceLayer": "Monin-Obukhov similarity",
          "mixing": "Prognostic TKE with length scale"
        },
        "landSurface": {
          "scheme": "JSBACH (external component)",
          "soilLevels": 5,
          "vegetation": "Dynamic with 12 PFTs"
        }
      },
      
      "emd:couplingInterfaces": ["ocean", "land", "seaIce"],
      "emd:exchangedVariables": {
        "toOcean": ["wind_stress_x", "wind_stress_y", "sensible_heat_flux", "latent_heat_flux", "shortwave_radiation", "longwave_radiation", "precipitation", "river_runoff"],
        "fromOcean": ["sea_surface_temperature", "sea_ice_concentration", "sea_ice_thickness", "ocean_surface_velocity"]
      }
    },
    
    "ocean": {
      "@type": "emd:ModelComponent",
      "@id": "https://mpimet.mpg.de/models/mpi-esm-1-2-lr/components/ocean",
      "emd:componentName": "MPIOM",
      "emd:componentType": "ocean",
      "emd:componentVersion": "1.6.3",
      "dcterms:description": "Max Planck Institute Ocean Model with embedded sea ice",
      
      "emd:spatialDiscretization": {
        "@type": "emd:Grid",
        "emd:gridType": "bipolar",
        "emd:horizontalResolution": "GR15 (~1.5°)",
        "emd:verticalResolution": "z-coordinate",
        "emd:verticalLevels": 40,
        "emd:maxDepth": "5720 m"
      },
      
      "emd:physicalParameterizations": {
        "mixing": {
          "vertical": "KPP (K-Profile Parameterization)",
          "horizontal": "Biharmonic for momentum, isopycnal for tracers",
          "eddyParameterization": "Gent-McWilliams with variable coefficient"
        },
        "seaIce": {
          "included": true,
          "seaIceModel": "Hibler-type dynamic-thermodynamic sea ice",
          "thermodynamics": "Zero-layer Semtner scheme",
          "dynamics": "Viscous-plastic rheology"
        }
      }
    },
    
    "land": {
      "@type": "emd:ModelComponent",
      "@id": "https://mpimet.mpg.de/models/mpi-esm-1-2-lr/components/land",
      "emd:componentName": "JSBACH",
      "emd:componentType": "land",
      "emd:componentVersion": "3.2",
      "dcterms:description": "Jena Scheme for Biosphere-Atmosphere Coupling in Hamburg",
      
      "emd:subcomponents": {
        "vegetation": {
          "dynamic": true,
          "pfts": 12,
          "phenology": "Temperature and moisture dependent"
        },
        "hydrology": {
          "runoffScheme": "TOPMODEL-based",
          "groundwater": false,
          "routing": "Linear reservoir cascade"
        },
        "carbon": {
          "included": true,
          "pools": ["leaf", "wood", "root", "litter", "fast_soil", "slow_soil"],
          "nitrogenCycle": false
        }
      }
    }
  },
  
  "emd:couplingConfiguration": {
    "@type": "emd:CouplingMethod",
    "emd:couplerName": "OASIS3-MCT v3.0",
    "emd:couplingFrequency": {
      "atmosphere-ocean": "hourly",
      "atmosphere-land": "every timestep",
      "ocean-seaIce": "every ocean timestep"
    },
    "emd:interpolationMethods": {
      "atmosphere-ocean": "conservative remapping",
      "atmosphere-land": "first-order conservative"
    },
    "emd:conservedQuantities": ["energy", "water", "momentum"],
    "emd:fluxAdjustments": "none"
  },
  
  "emd:systemArchitecture": {
    "@type": "emd:Architecture",
    "emd:executableStructure": "multiple executables",
    "emd:parallelizationStrategy": "domain_decomposition",
    "emd:loadBalancing": "static",
    "emd:communicationProtocol": "MPI"
  },
  
  "emd:performanceProfile": {
    "@type": "emd:Performance",
    "emd:typicalProcessorAllocation": {
      "atmosphere": 96,
      "ocean": 144,
      "land": 24,
      "coupler": 24
    },
    "emd:scalingEfficiency": "strong scaling to 576 cores",
    "emd:memoryRequirements": "4 GB per core"
  },
  
  "prov:generatedAtTime": "2023-11-15T10:00:00Z"
}
