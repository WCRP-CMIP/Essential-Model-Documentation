  "emd:modelName": "MPI Earth System Model",
  "emd:modelVersion": "1.2",
  "emd:modelAcronym": "MPI-ESM1.2-LR",
  "emd:modelLineage": "MPI-ESM1.0",
  
  "emd:institutionName": "Max Planck Institute for Meteorology",
  "emd:institutionAcronym": "MPI-M",
  "emd:institutionCountry": "Germany",
  "emd:institutionType": "research",
  "emd:modelDevelopmentCenter": "Hamburg, Germany",
  "emd:institutionURL": "https://www.mpimet.mpg.de",
  
  "dcterms:description": "The MPI-ESM1.2-LR is the low resolution version of the Max Planck Institute Earth System Model version 1.2, used for CMIP6 experiments. It couples atmosphere, ocean, land surface and biogeochemical components through the OASIS3-MCT coupler.",
  "dcterms:created": "2017-01-01",
  "dcterms:modified": "2023-11-15",
  "emd:modelType": "ESM",
  "emd:modelScope": "global",
  
  "emd:componentSummary": {
    "atmosphere": {
      "componentName": "ECHAM6.3",
      "componentVersion": "6.3",
      "resolution": "T63L47 (~1.875°)"
    },
    "ocean": {
      "componentName": "MPIOM",
      "componentVersion": "1.6.3",
      "resolution": "GR15L40 (~1.5°)"
    },
    "land": {
      "componentName": "JSBACH",
      "componentVersion": "3.2",
      "resolution": "T63 (~1.875°)"
    },
    "seaIce": {
      "componentName": "Sea ice (embedded in MPIOM)",
      "componentVersion": "1.0",
      "resolution": "GR15 (~1.5°)"
    }
  },
  
