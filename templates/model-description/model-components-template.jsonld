{
  "@context": {
    "@vocab": "https://wcrp-cmip.org/emd/",
    "emd": "https://wcrp-cmip.org/emd/",
    "dcterms": "http://purl.org/dc/terms/",
    "prov": "http://www.w3.org/ns/prov#",
    "gcmd": "https://gcmd.earthdata.nasa.gov/kms/concepts/concept_scheme/sciencekeywords/"
  },
  "@type": "emd:ModelComponents",
  "@id": "https://[INSTITUTION_DOMAIN]/models/[MODEL_ID]/components",
  
  "emd:parentModelId": "https://[INSTITUTION_DOMAIN]/models/[MODEL_ID]",
  "emd:parentModelName": "[Model Name and Version]",
  
  "emd:components": {
    "atmosphere": {
      "@type": "emd:ModelComponent",
      "@id": "https://[INSTITUTION_DOMAIN]/models/[MODEL_ID]/components/atmosphere",
      "emd:componentName": "[Component Name]",
      "emd:componentType": "atmosphere",
      "emd:componentVersion": "[X.Y.Z]",
      "dcterms:description": "[Component description]",
      
      "emd:spatialDiscretization": {
        "@type": "emd:Grid",
        "emd:gridType": "[spectral|finite_difference|finite_volume|finite_element]",
        "emd:horizontalResolution": "[e.g., T63 (~1.875°)]",
        "emd:horizontalGridPoints": null,
        "emd:verticalResolution": "[sigma|pressure|hybrid|height]",
        "emd:verticalLevels": null,
        "emd:topHeight": "[e.g., 0.01 hPa]",
        "emd:verticalCoordinateScheme": "[Description of vertical coordinate]"
      },
      
      "emd:temporalDiscretization": {
        "@type": "emd:TimeStep",
        "emd:dynamicalCoreTimeStep": null,
        "emd:physicsTimeStep": null,
        "emd:radiationTimeStep": null,
        "emd:timeStepUnit": "seconds",
        "emd:timeIntegrationScheme": "[leapfrog|semi-implicit|explicit]"
      },
      
      "emd:dynamicalCore": {
        "@type": "emd:DynamicalCore",
        "emd:coreName": "[Name]",
        "emd:coreType": "[spectral|gridpoint]",
        "emd:prognosticVariables": [],
        "emd:conservedQuantities": []
      },
      
      "emd:physicalParameterizations": {
        "radiation": {
          "scheme": "[Scheme name]",
          "shortwave": "[SW radiation scheme]",
          "longwave": "[LW radiation scheme]",
          "spectralBands": null
        },
        "convection": {
          "scheme": "[Scheme name]",
          "deepConvection": "[Deep convection scheme]",
          "shallowConvection": "[Shallow convection scheme]",
          "trigger": "[Convection trigger]"
        },
        "clouds": {
          "scheme": "[Cloud scheme]",
          "prognosticVariables": [],
          "microphysics": "[Microphysics scheme]"
        },
        "turbulence": {
          "scheme": "[PBL scheme]",
          "surfaceLayer": "[Surface layer scheme]",
          "mixing": "[Mixing scheme]"
        },
        "landSurface": {
          "scheme": "[Land surface scheme]",
          "soilLevels": null,
          "vegetation": "[Vegetation treatment]"
        }
      },
      
      "emd:couplingInterfaces": [],
      "emd:exchangedVariables": {
        "toOcean": [],
        "fromOcean": []
      }
    },
    
    "ocean": {
      "@type": "emd:ModelComponent",
      "@id": "https://[INSTITUTION_DOMAIN]/models/[MODEL_ID]/components/ocean",
      "emd:componentName": "[Component Name]",
      "emd:componentType": "ocean",
      "emd:componentVersion": "[X.Y.Z]",
      "dcterms:description": "[Component description]",
      
      "emd:spatialDiscretization": {
        "@type": "emd:Grid",
        "emd:gridType": "[regular|tripolar|unstructured]",
        "emd:horizontalResolution": "[e.g., 1°]",
        "emd:verticalResolution": "[z|sigma|hybrid|isopycnal]",
        "emd:verticalLevels": null,
        "emd:maxDepth": "[m]"
      },
      
      "emd:physicalParameterizations": {
        "mixing": {
          "vertical": "[Vertical mixing scheme]",
          "horizontal": "[Horizontal mixing scheme]",
          "eddyParameterization": "[GM/Redi scheme]"
        },
        "seaIce": {
          "included": true,
          "seaIceModel": "[Sea ice model name]",
          "thermodynamics": "[Thermodynamics scheme]",
          "dynamics": "[Dynamics scheme]"
        }
      }
    },
    
    "land": {
      "@type": "emd:ModelComponent",
      "@id": "https://[INSTITUTION_DOMAIN]/models/[MODEL_ID]/components/land",
      "emd:componentName": "[Component Name]",
      "emd:componentType": "land",
      "emd:componentVersion": "[X.Y.Z]",
      "dcterms:description": "[Component description]",
      
      "emd:subcomponents": {
        "vegetation": {
          "dynamic": true,
          "pfts": null,
          "phenology": "[Phenology scheme]"
        },
        "hydrology": {
          "runoffScheme": "[Runoff scheme]",
          "groundwater": true,
          "routing": "[River routing scheme]"
        },
        "carbon": {
          "included": true,
          "pools": [],
          "nitrogenCycle": false
        }
      }
    }
  },
  
  "emd:couplingConfiguration": {
    "@type": "emd:CouplingMethod",
    "emd:couplerName": "[Coupler name and version]",
    "emd:couplingFrequency": {
      "atmosphere-ocean": "[hourly]",
      "atmosphere-land": "[time step]",
      "ocean-seaIce": "[time step]"
    },
    "emd:interpolationMethods": {
      "atmosphere-ocean": "[conservative|bilinear]",
      "atmosphere-land": "[first-order|second-order]"
    },
    "emd:conservedQuantities": [],
    "emd:fluxAdjustments": "none"
  },
  
  "emd:systemArchitecture": {
    "@type": "emd:Architecture",
    "emd:executableStructure": "[single|multiple]",
    "emd:parallelizationStrategy": "[domain_decomposition|task_parallel]",
    "emd:loadBalancing": "[static|dynamic]",
    "emd:communicationProtocol": "[MPI|MPI+OpenMP]"
  },
  
  "emd:performanceProfile": {
    "@type": "emd:Performance",
    "emd:typicalProcessorAllocation": {
      "atmosphere": null,
      "ocean": null,
      "land": null,
      "coupler": null
    },
    "emd:scalingEfficiency": "[strong|weak]",
    "emd:memoryRequirements": "[GB per node]"
  },
  
  "prov:generatedAtTime": "YYYY-MM-DDTHH:MM:SSZ"
}
