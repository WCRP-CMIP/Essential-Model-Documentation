{
  "@context": {
    "@vocab": "https://wcrp-cmip.org/emd/",
    "emd": "https://wcrp-cmip.org/emd/",
    "dcterms": "http://purl.org/dc/terms/",
    "prov": "http://www.w3.org/ns/prov#",
    "xsd": "http://www.w3.org/2001/XMLSchema#"
  },
  "@type": "emd:QualityAssurance",
  "@id": "https://[INSTITUTION_DOMAIN]/qa/[QA_ID]",
  
  "emd:qaTitle": "[Quality Assurance Report Title]",
  "dcterms:description": "[Comprehensive description of QA scope and objectives]",
  
  "emd:targetModelId": "https://[INSTITUTION_DOMAIN]/models/[MODEL_ID]",
  "emd:targetModelName": "[Model Name and Version]",
  
  "emd:targetSimulationId": "https://[INSTITUTION_DOMAIN]/simulations/[SIMULATION_ID]",
  "emd:targetExperimentId": "[Experiment ID]",
  
  "emd:validationTests": [
    {
      "@type": "emd:ValidationTest",
      "emd:testName": "[Test Name]",
      "emd:testType": "[climatology|variability|trends|extremes]",
      "emd:testDescription": "[Detailed test description]",
      "emd:testProcedure": "[Step-by-step procedure]",
      "emd:referenceDataset": "[Reference dataset name and version]",
      "emd:referenceDatasetURL": "[URL to reference data]",
      "emd:testPeriod": {
        "startDate": "YYYY-MM-DD",
        "endDate": "YYYY-MM-DD"
      },
      "emd:testMetrics": [
        {
          "@type": "emd:Metric",
          "emd:metricName": "[bias|RMSE|correlation|pattern_correlation|etc]",
          "emd:metricValue": null,
          "emd:metricUnit": "[Unit]",
          "emd:acceptanceThreshold": null,
          "emd:acceptanceRange": {
            "min": null,
            "max": null
          }
        }
      ],
      "emd:testResult": {
        "@type": "emd:TestOutcome",
        "emd:passed": null,
        "emd:resultSummary": "[Summary of results]",
        "emd:resultDetails": "[Detailed explanation]",
        "emd:confidenceLevel": "[high|medium|low]"
      }
    }
  ],
  
  "emd:performanceTests": [
    {
      "@type": "emd:PerformanceTest",
      "emd:testName": "[Performance Test Name]",
      "emd:testDescription": "[Test description]",
      "emd:scalingType": "[strong|weak]",
      "emd:hardwarePlatform": "[Platform description]",
      "emd:performanceMetrics": [
        {
          "@type": "emd:PerformanceMetric",
          "emd:metricName": "[speedup|efficiency|throughput]",
          "emd:coreCount": null,
          "emd:nodeCount": null,
          "emd:metricValue": null,
          "emd:metricUnit": "[relative|SYPD|wallclock_hours]",
          "emd:theoreticalMaximum": null
        }
      ],
      "emd:bottlenecks": [],
      "emd:optimizationNotes": "[Notes on optimizations]"
    }
  ],
  
  "emd:conservationChecks": [
    {
      "@type": "emd:ConservationCheck",
      "emd:conservedQuantity": "[energy|mass|water|momentum|tracer]",
      "emd:checkMethod": "[Method description]",
      "emd:checkFrequency": "[every_timestep|daily|monthly]",
      "emd:tolerance": null,
      "emd:toleranceType": "[absolute|relative]",
      "emd:result": {
        "@type": "emd:ConservationResult",
        "emd:isConserved": null,
        "emd:maxDeviation": null,
        "emd:meanDeviation": null,
        "emd:deviationUnit": "[Unit]",
        "emd:deviationLocation": "[Where deviation occurs]",
        "emd:deviationTime": "[When deviation occurs]"
      }
    }
  ],
  
  "emd:reproducibilityTests": [
    {
      "@type": "emd:ReproducibilityTest",
      "emd:testType": "[bit-identical|statistically-identical|restart|compiler|platform]",
      "emd:testDescription": "[Test description]",
      "emd:testConfiguration": {
        "compilers": [],
        "platforms": [],
        "parallelization": []
      },
      "emd:isReproducible": null,
      "emd:reproducibilityLevel": "[bit-for-bit|statistical|none]",
      "emd:reproducibilityDetails": "[Detailed explanation]",
      "emd:deviationThreshold": null
    }
  ],
  
  "emd:numericalStability": {
    "@type": "emd:StabilityAnalysis",
    "emd:cflCondition": {
      "satisfied": null,
      "maxCFL": null,
      "criticalRegions": []
    },
    "emd:numericalNoise": {
      "level": "[low|medium|high]",
      "sources": [],
      "mitigation": []
    },
    "emd:crashTests": {
      "crashFrequency": null,
      "commonCauses": [],
      "robustness": "[high|medium|low]"
    }
  },
  
  "emd:dataComplianceChecks": {
    "@type": "emd:ComplianceCheck",
    "emd:standards": ["CF-1.8", "CMIP6", "CMOR3"],
    "emd:checksPerformed": [
      {
        "standard": "[Standard name]",
        "tool": "[Tool name and version]",
        "passed": null,
        "issues": []
      }
    ],
    "emd:metadataCompleteness": null,
    "emd:formatCompliance": null
  },
  
  "emd:knownIssues": [
    {
      "@type": "emd:Issue",
      "emd:issueID": "[ISSUE-YYYY-NNN]",
      "emd:issueDescription": "[Description]",
      "emd:issueSeverity": "[critical|major|minor|cosmetic]",
      "emd:issueStatus": "[open|acknowledged|fixed|wont-fix]",
      "emd:issueWorkaround": "[Workaround if available]",
      "emd:affectedVariables": [],
      "emd:affectedRegions": [],
      "emd:reportedDate": "YYYY-MM-DD",
      "emd:fixedDate": "YYYY-MM-DD"
    }
  ],
  
  "emd:qaProcess": {
    "@type": "emd:QAProcess",
    "emd:qaVersion": "[QA protocol version]",
    "emd:qaTools": [
      {
        "toolName": "[Tool name]",
        "toolVersion": "[Version]",
        "toolPurpose": "[Purpose]"
      }
    ],
    "emd:qaFrequency": "[continuous|milestone|release]",
    "emd:automationLevel": "[fully-automated|semi-automated|manual]"
  },
  
  "emd:qaReport": {
    "@type": "emd:Report",
    "emd:reportURL": "https://[INSTITUTION_DOMAIN]/reports/[REPORT_ID]",
    "emd:reportFormat": "[PDF|HTML|JSON]",
    "dcterms:created": "YYYY-MM-DD",
    "emd:reportSections": [],
    "emd:executiveSummary": "[Summary]"
  },
  
  "prov:wasAssociatedWith": {
    "@type": "prov:Agent",
    "foaf:name": "[QA Team Name]",
    "foaf:organization": "[Organization]"
  },
  
  "prov:generatedAtTime": "YYYY-MM-DDTHH:MM:SSZ",
  "prov:used": [
    "[Reference to test data]",
    "[Reference to analysis tools]"
  ]
}
