{
  "@context": {
    "@vocab": "https://wcrp-cmip.org/emd/",
    "emd": "https://wcrp-cmip.org/emd/",
    "dcterms": "http://purl.org/dc/terms/",
    "prov": "http://www.w3.org/ns/prov#",
    "mip": "https://wcrp-cmip.org/mip/",
    "xsd": "http://www.w3.org/2001/XMLSchema#"
  },
  "@type": "emd:ExperimentDesign",
  "@id": "https://[INSTITUTION_DOMAIN]/experiments/[EXPERIMENT_ID]-[VARIANT]",
  
  "emd:experimentName": "[Full Experiment Name]",
  "emd:experimentID": "[Standard experiment_id from CV]",
  "emd:mipEra": "[CMIP6|CMIP7]",
  "emd:activity": "[CMIP|ScenarioMIP|DCPP|etc.]",
  "emd:experimentTier": null,
  
  "dcterms:description": "[Comprehensive description of experiment purpose and design]",
  
  "emd:simulationPeriod": {
    "@type": "emd:TemporalExtent",
    "emd:startDate": "YYYY-MM-DD",
    "emd:endDate": "YYYY-MM-DD",
    "emd:calendar": "[gregorian|365_day|360_day]",
    "emd:runLength": "[Number of years]",
    "emd:spinupPeriod": "[Years of spinup if applicable]"
  },
  
  "emd:forcings": [
    {
      "@type": "emd:Forcing",
      "emd:forcingType": "[GHG|aerosol|solar|volcanic|landUse|ozone]",
      "emd:forcingDataset": "[Dataset name and version]",
      "emd:forcingDescription": "[Detailed description]",
      "emd:forcingSource": "[URL or reference to forcing data]",
      "emd:forcingTimeSpan": {
        "@type": "emd:TemporalExtent",
        "emd:startDate": "YYYY-MM-DD",
        "emd:endDate": "YYYY-MM-DD",
        "emd:temporalResolution": "[annual|monthly|daily]"
      },
      "emd:forcingTreatment": "[prescribed|interactive|prognostic]",
      "emd:forcingVariables": []
    }
  ],
  
  "emd:boundaryConditions": [
    {
      "@type": "emd:BoundaryCondition",
      "emd:conditionType": "[SST|seaIce|land_use|vegetation]",
      "emd:conditionSource": "[Dataset name]",
      "emd:conditionDescription": "[Description]",
      "emd:updateFrequency": "[fixed|annual|monthly|daily]",
      "emd:spatialCoverage": "[global|regional]",
      "emd:conditionTreatment": "[prescribed|interactive]"
    }
  ],
  
  "emd:initialConditions": {
    "@type": "emd:InitialCondition",
    "emd:initializationType": "[spinup|branch|hybrid]",
    "emd:initializationMethod": "[Detailed method description]",
    "emd:initializationDate": "YYYY-MM-DD",
    "emd:parentExperimentId": "[parent_experiment_id]",
    "emd:parentSimulationId": "https://[INSTITUTION_DOMAIN]/simulations/[PARENT_SIM_ID]",
    "emd:branchTimeInParent": "[Year or date in parent]",
    "emd:initializationFiles": []
  },
  
  "emd:ensembleInfo": {
    "@type": "emd:Ensemble",
    "emd:ensembleSize": null,
    "emd:perturbationMethod": "[none|initial_conditions|physics|forcing]",
    "emd:perturbationDescription": "[Detailed description of perturbations]",
    "emd:realization_index": null,
    "emd:initialization_index": null,
    "emd:physics_index": null,
    "emd:forcing_index": null,
    "emd:variant_label": "r[N]i[N]p[N]f[N]"
  },
  
  "emd:conformsTo": {
    "@id": "https://wcrp-cmip.org/[PROJECT]/experiment-protocols/[EXPERIMENT_ID]",
    "@type": "mip:ExperimentProtocol",
    "emd:protocolVersion": "[Version number]",
    "emd:protocolURL": "[URL to protocol document]"
  },
  
  "emd:modelConfiguration": {
    "@type": "emd:ExperimentModelConfig",
    "emd:requiredComponents": [],
    "emd:optionalComponents": [],
    "emd:componentCoupling": "[fully_coupled|prescribed_SST]",
    "emd:resolution": "[high|medium|low]"
  },
  
  "emd:outputRequirements": {
    "@type": "emd:OutputSpec",
    "emd:outputFrequencies": [],
    "emd:priorityVariables": [],
    "emd:outputTables": [],
    "emd:dataVolume": "[Estimated TB]"
  },
  
  "prov:wasGeneratedBy": {
    "@type": "prov:Activity",
    "prov:startedAtTime": "YYYY-MM-DDTHH:MM:SSZ",
    "prov:endedAtTime": "YYYY-MM-DDTHH:MM:SSZ",
    "prov:wasAssociatedWith": "https://[INSTITUTION_DOMAIN]/models/[MODEL_ID]"
  },
  
  "emd:scientificObjectives": [],
  "emd:targetedProcesses": [],
  "emd:relatedExperiments": [],
  "emd:experimentNotes": "[Any special notes or deviations]"
}
