{
  "@context": {
    "@vocab": "https://wcrp-cmip.org/emd/",
    "emd": "https://wcrp-cmip.org/emd/",
    "dcterms": "http://purl.org/dc/terms/",
    "prov": "http://www.w3.org/ns/prov#",
    "xsd": "http://www.w3.org/2001/XMLSchema#"
  },
  "@type": "emd:SimulationRun",
  "@id": "https://[INSTITUTION_DOMAIN]/simulations/[SIMULATION_ID]",
  
  "emd:simulationID": "[MODEL_ID]-[EXPERIMENT_ID]-[VARIANT_LABEL]",
  "emd:experimentID": "[EXPERIMENT_ID]",
  "emd:modelID": "https://[INSTITUTION_DOMAIN]/models/[MODEL_ID]",
  "emd:modelName": "[Model Name and Version]",
  "emd:variantLabel": "r[N]i[N]p[N]f[N]",
  
  "emd:simulationStatus": {
    "@type": "emd:Status",
    "emd:currentStatus": "[planned|running|completed|failed|archived]",
    "emd:completionPercentage": null,
    "emd:statusMessage": "[Status description]",
    "emd:lastUpdate": "YYYY-MM-DDTHH:MM:SSZ"
  },
  
  "emd:hardwareEnvironment": {
    "@type": "emd:ComputingEnvironment",
    "emd:systemName": "[HPC System Name]",
    "emd:systemVendor": "[Vendor Name]",
    "emd:systemLocation": "[Institution, City]",
    "emd:systemType": "[cluster|supercomputer|cloud]",
    "emd:nodeConfiguration": {
      "@type": "emd:NodeSpec",
      "emd:cpuType": "[CPU Model]",
      "emd:cpuArchitecture": "[x86_64|ARM|Power]",
      "emd:cpuCoresPerNode": null,
      "emd:cpuFrequency": "[GHz]",
      "emd:memoryPerNode": "[GB]",
      "emd:memoryType": "[DDR4|DDR5|HBM]",
      "emd:acceleratorType": "[none|GPU model]",
      "emd:acceleratorsPerNode": null,
      "emd:interconnect": "[InfiniBand|Ethernet|Custom]",
      "emd:interconnectBandwidth": "[Gb/s]"
    },
    "emd:storageConfiguration": {
      "@type": "emd:Storage",
      "emd:fileSystem": "[Lustre|GPFS|BeeGFS]",
      "emd:storageCapacity": "[PB]",
      "emd:storageBandwidth": "[GB/s]",
      "emd:scratchSpace": "[TB]"
    }
  },
  
  "emd:resourcesUsed": {
    "@type": "emd:ComputationalResources",
    "emd:numberOfNodes": null,
    "emd:totalCores": null,
    "emd:totalCoreHours": null,
    "emd:peakMemoryUsage": "[GB]",
    "emd:wallClockTime": "[hours]",
    "emd:queueTime": "[hours]",
    "emd:parallelizationStrategy": "[domain|task|hybrid]",
    "emd:mpiProcesses": null,
    "emd:openmpThreads": null,
    "emd:processLayout": {
      "atmosphere": null,
      "ocean": null,
      "land": null,
      "seaIce": null,
      "coupler": null
    }
  },
  
  "emd:softwareEnvironment": {
    "@type": "emd:SoftwareStack",
    "emd:operatingSystem": "[OS Name and Version]",
    "emd:kernel": "[Kernel version]",
    "emd:moduleSystem": "[Lmod|Environment Modules|Spack]",
    "emd:compiler": {
      "@type": "emd:Compiler",
      "emd:compilerName": "[Intel|GNU|PGI|Cray]",
      "emd:compilerVersion": "[Version]",
      "emd:fortranCompiler": "[ifort|gfortran|pgfortran]",
      "emd:cCompiler": "[icc|gcc|pgcc]",
      "emd:cppCompiler": "[icpc|g++|pgc++]",
      "emd:optimizationFlags": [],
      "emd:debugFlags": [],
      "emd:preprocessorFlags": []
    },
    "emd:mpiImplementation": {
      "@type": "emd:MPILibrary",
      "emd:mpiName": "[Intel MPI|OpenMPI|MPICH|Cray MPICH]",
      "emd:mpiVersion": "[Version]",
      "emd:mpiCompilerWrapper": "[mpif90|mpifort]"
    },
    "emd:dependencies": [
      {
        "@type": "emd:SoftwareDependency",
        "emd:libraryName": "[Library Name]",
        "emd:libraryVersion": "[Version]",
        "emd:libraryPurpose": "[Purpose]",
        "emd:libraryPath": "[/path/to/library]",
        "emd:moduleCommand": "[module load command]"
      }
    ],
    "emd:environmentVariables": {
      "OMP_NUM_THREADS": "[Value]",
      "OMP_STACKSIZE": "[Value]",
      "KMP_AFFINITY": "[Value]",
      "NETCDF_PATH": "[Path]"
    }
  },
  
  "emd:modelConfiguration": {
    "@type": "emd:ModelSettings",
    "emd:configurationFiles": [
      {
        "@type": "emd:ConfigFile",
        "emd:fileName": "[namelist.component]",
        "emd:filePath": "[/path/to/file]",
        "emd:fileChecksum": "[sha256:hash]",
        "emd:fileDescription": "[Component configuration]",
        "emd:fileFormat": "[namelist|xml|json|yaml]"
      }
    ],
    "emd:keyParameters": [
      {
        "@type": "emd:Parameter",
        "emd:parameterName": "[Parameter name]",
        "emd:parameterValue": "[Value]",
        "emd:parameterUnit": "[Unit]",
        "emd:parameterDescription": "[Description]",
        "emd:parameterCategory": "[physics|dynamics|numerics|output]"
      }
    ],
    "emd:resolutionSettings": {
      "atmosphere": {
        "horizontal": "[Resolution]",
        "vertical": "[Levels]",
        "timestep": "[seconds]"
      },
      "ocean": {
        "horizontal": "[Resolution]",
        "vertical": "[Levels]",
        "timestep": "[seconds]"
      }
    },
    "emd:outputConfiguration": {
      "outputFrequency": "[hourly|daily|monthly]",
      "outputVariables": null,
      "outputFormat": "netCDF4",
      "compressionLevel": null
    }
  },
  
  "emd:performanceMetrics": {
    "@type": "emd:Performance",
    "emd:simulatedYearsPerDay": null,
    "emd:coreHoursPerSimulatedYear": null,
    "emd:throughput": "[timesteps/second]",
    "emd:parallelEfficiency": null,
    "emd:loadBalance": {
      "componentBalance": "[balanced|imbalanced]",
      "maxLoadImbalance": null
    },
    "emd:memoryUsage": {
      "peakMemoryPerCore": "[GB]",
      "totalMemoryFootprint": "[GB]"
    },
    "emd:ioPerformance": {
      "writeSpeed": "[GB/s]",
      "readSpeed": "[GB/s]",
      "ioWaitTime": "[percentage]"
    },
    "emd:storagePerSimulatedYear": "[TB]",
    "emd:checkpointFrequency": "[days]",
    "emd:checkpointSize": "[GB]"
  },
  
  "emd:dataManagement": {
    "@type": "emd:DataHandling",
    "emd:outputLocation": "[/path/to/output]",
    "emd:archiveLocation": "[/path/to/archive]",
    "emd:backupStrategy": "[incremental|full|snapshot]",
    "emd:retentionPolicy": "[permanent|N years]",
    "emd:dataTransfer": {
      "method": "[rsync|gridftp|globus]",
      "destination": "[Archive system]",
      "bandwidth": "[GB/s]"
    }
  },
  
  "emd:workflowManagement": {
    "@type": "emd:Workflow",
    "emd:workflowSystem": "[cylc|ecFlow|SLURM]",
    "emd:jobScheduler": "[SLURM|PBS|LSF]",
    "emd:jobScript": "[/path/to/job/script]",
    "emd:restartCapability": true,
    "emd:checkpointingEnabled": true,
    "emd:errorHandling": "[automatic|manual]",
    "emd:notificationSystem": "[email|slack|none]"
  },
  
  "emd:qualityControl": {
    "@type": "emd:RuntimeQC",
    "emd:runtimeChecks": ["conservation", "stability", "range"],
    "emd:postProcessingQC": ["CMOR compliance", "CF compliance"],
    "emd:anomalyDetection": true,
    "emd:autoCorrection": false
  },
  
  "prov:startedAtTime": "YYYY-MM-DDTHH:MM:SSZ",
  "prov:endedAtTime": "YYYY-MM-DDTHH:MM:SSZ",
  "prov:wasAssociatedWith": {
    "@type": "prov:Agent",
    "foaf:name": "[Production Team Name]",
    "foaf:organization": "[Institution]"
  },
  
  "emd:simulationNotes": "[Any special notes about the simulation run]",
  "emd:incidents": [
    {
      "incidentDate": "YYYY-MM-DD",
      "incidentType": "[crash|restart|performance]",
      "incidentDescription": "[Description]",
      "incidentResolution": "[How it was resolved]"
    }
  ]
}
